---
import { Image } from "astro:assets"
import kumo from "@/assets/kumo.png"

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Music", href: "/music" },
  { label: "Submissions", href: "/submissions" },
  { label: "Contact", href: "/contact" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<header class="w-screen border-b border-neutral-200">
  <div class="grid grid-cols-[1fr_auto_1fr] items-center px-8 h-16">
    <!-- デスクトップ: ナビリンク（左） -->
    <nav class="hidden lg:flex gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm tracking-widest uppercase hover:text-neutral-500 transition-colors ${isActive(link.href) ? "underline underline-offset-4 decoration-neutral-400" : ""}`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- モバイル・タブレット: 左は空白 -->
    <div class="lg:hidden"></div>

    <!-- 中央: アイコン -->
    <a href="/" class="justify-self-center">
      <Image
        src={kumo}
        alt="Hydrometeor"
        width={40}
        height={40}
        class="object-contain"
      />
    </a>

    <!-- 右: ハンバーガー / バツボタン（モバイル・タブレット） -->
    <div class="flex justify-end">
      <button
        id="menu-toggle"
        class="lg:hidden"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <!-- ハンバーガーアイコン -->
        <span id="icon-open" class="flex flex-col gap-1 w-6">
          <span class="block w-full h-px bg-neutral-900"></span>
          <span class="block w-full h-px bg-neutral-900"></span>
          <span class="block w-full h-px bg-neutral-900"></span>
        </span>
        <!-- バツアイコン -->
        <span
          id="icon-close"
          class="hidden w-6 h-6 items-center justify-center text-xl leading-none"
          >✕</span
        >
      </button>
    </div>
  </div>

  <!-- モバイル: ドロップダウンメニュー -->
  <nav id="mobile-menu" class="hidden lg:hidden border-t border-neutral-200">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={`block px-8 py-4 text-sm tracking-widest uppercase border-b border-neutral-100 hover:bg-neutral-50 transition-colors ${isActive(link.href) ? "underline underline-offset-4" : ""}`}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")
  const menu = document.getElementById("mobile-menu")

  const iconOpen = document.getElementById("icon-open")
  const iconClose = document.getElementById("icon-close")

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden")
    menu?.classList.toggle("hidden", isOpen)
    toggle.setAttribute("aria-expanded", String(!isOpen))
    iconOpen?.classList.toggle("hidden", !isOpen)
    iconClose?.classList.toggle("hidden", isOpen)
    iconClose?.classList.toggle("flex", !isOpen)
  })
</script>
