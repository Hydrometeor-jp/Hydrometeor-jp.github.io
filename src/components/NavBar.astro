---
import { Image } from "astro:assets"

import ThemeIcon from "./ThemeIcon.astro"

import kumo from "@/assets/kumo.png"

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Music", href: "/music/" },
  { label: "Blogs", href: "/blogs/" },
  { label: "Contact", href: "/contact/" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<header class="w-full">
  <div
    class="grid h-16 grid-cols-[1fr_auto_1fr] items-center border-b border-neutral-200 px-8 dark:border-neutral-700"
  >
    <!-- デスクトップ: ナビリンク（左） -->
    <nav class="hidden gap-8 lg:flex">
      {
        navLinks.map((link) =>
          isActive(link.href) ? (
            <div class="text-sm tracking-widest uppercase underline decoration-neutral-400 underline-offset-4">
              {link.label}
            </div>
          ) : (
            <a
              href={link.href}
              class="text-sm tracking-widest uppercase transition-opacity hover:opacity-80"
            >
              {link.label}
            </a>
          ),
        )
      }
    </nav>

    <!-- モバイル・タブレット: 左は空白 -->
    <div class="lg:hidden"></div>

    <!-- 中央: アイコン -->
    <a id="nav-icon-link" href="/" class="justify-self-center rounded-full">
      <Image
        id="nav-icon"
        src={kumo}
        alt="Hydrometeor"
        width={40}
        height={40}
        class="object-contain dark:invert"
      />
    </a>

    <!-- 右: ハンバーガー / バツボタン（モバイル・タブレット） -->
    <div class="flex items-center justify-end gap-4">
      <ThemeIcon class="hidden lg:inline-block" />
      <button
        id="menu-toggle"
        class="cursor-pointer lg:hidden"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <!-- ハンバーガーアイコン -->
        <span id="icon-open" class="flex w-6 flex-col gap-1">
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
        </span>
        <!-- バツアイコン -->
        <span
          id="icon-close"
          class="hidden h-6 w-6 items-center justify-center text-xl leading-none"
          >✕</span
        >
      </button>
    </div>
  </div>

  <!-- モバイル: ドロップダウンメニュー -->
  <nav
    id="mobile-menu"
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out lg:hidden"
  >
    <div class="overflow-hidden">
      {
        navLinks.map((link) =>
          isActive(link.href) ? (
            <div class="block border-b border-neutral-100 px-8 py-4 text-center text-sm tracking-widest uppercase underline underline-offset-4 dark:border-neutral-700">
              {link.label}
            </div>
          ) : (
            <a
              href={link.href}
              class="block border-b border-neutral-100 px-8 py-4 text-center text-sm tracking-widest uppercase transition-colors hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800"
            >
              {link.label}
            </a>
          ),
        )
      }
      <div
        class="border-b border-neutral-100 px-8 py-4 text-center dark:border-neutral-700"
      >
        <ThemeIcon />
      </div>
    </div>
  </nav>
</header>

<script>
  // ナビアイコン: hover 中はゆっくり回転、離すと元の向きへ戻す
  const SPIN_DURATION_MS = 3000
  const RETURN_DURATION_MS = 600

  const getCurrentAngle = (el: HTMLElement) => {
    const transform = getComputedStyle(el).transform
    if (transform === "none") return 0
    const match = transform.match(/matrix\(([^)]+)\)/)
    if (!match) return 0
    const [a, b] = match[1].split(",").map(Number)
    return Math.atan2(b, a) * (180 / Math.PI)
  }

  const setupMenuToggle = () => {
    const toggle = document.getElementById("menu-toggle")
    const menu = document.getElementById("mobile-menu")
    const iconOpen = document.getElementById("icon-open")
    const iconClose = document.getElementById("icon-close")

    toggle?.addEventListener("click", () => {
      const willOpen = toggle.getAttribute("aria-expanded") !== "true"
      menu?.classList.toggle("grid-rows-[1fr]", willOpen)
      menu?.classList.toggle("grid-rows-[0fr]", !willOpen)
      toggle.setAttribute("aria-expanded", String(willOpen))
      iconOpen?.classList.toggle("hidden", willOpen)
      iconClose?.classList.toggle("hidden", !willOpen)
      iconClose?.classList.toggle("flex", willOpen)
    })
  }

  const setupNavIcon = () => {
    const navIcon = document.getElementById("nav-icon")
    const navIconLink = document.getElementById("nav-icon-link")
    if (!(navIcon instanceof HTMLElement) || !navIconLink) return

    let animation: Animation | null = null

    navIconLink.addEventListener("mouseenter", () => {
      const start = getCurrentAngle(navIcon)
      animation?.cancel()
      animation = navIcon.animate(
        [
          { transform: `rotate(${start}deg)` },
          { transform: `rotate(${start + 360}deg)` },
        ],
        { duration: SPIN_DURATION_MS, iterations: Infinity },
      )
    })

    navIconLink.addEventListener("mouseleave", () => {
      const current = getCurrentAngle(navIcon)
      // 0〜360 に正規化し、常に時計回り（角度を増やす方向）で 360deg へ戻す
      const normalized = ((current % 360) + 360) % 360
      const target = normalized === 0 ? 0 : 360
      animation?.cancel()
      animation = navIcon.animate(
        [
          { transform: `rotate(${normalized}deg)` },
          { transform: `rotate(${target}deg)` },
        ],
        { duration: RETURN_DURATION_MS, easing: "ease-out", fill: "forwards" },
      )
    })
  }

  // View Transitions 後も再バインドされるよう astro:page-load で初期化する
  document.addEventListener("astro:page-load", () => {
    setupMenuToggle()
    setupNavIcon()
  })
</script>
