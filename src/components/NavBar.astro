---
import { Image } from "astro:assets"

import ThemeIcon from "./ThemeIcon.astro"

import kumo from "@/assets/kumo.png"

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Music", href: "/music/" },
  { label: "Blogs", href: "/blogs/" },
  { label: "Contact", href: "/contact/" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<header class="w-full border-b border-neutral-200 dark:border-neutral-700">
  <div class="grid h-16 grid-cols-[1fr_auto_1fr] items-center px-8">
    <!-- デスクトップ: ナビリンク（左） -->
    <nav class="hidden gap-8 lg:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-sm tracking-widest uppercase transition-opacity hover:opacity-80 ${isActive(link.href) ? "underline decoration-neutral-400 underline-offset-4" : ""}`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- モバイル・タブレット: 左は空白 -->
    <div class="lg:hidden"></div>

    <!-- 中央: アイコン -->
    <a href="/" class="justify-self-center rounded-full bg-white p-1">
      <Image
        src={kumo}
        alt="Hydrometeor"
        width={32}
        height={32}
        class="object-contain"
      />
    </a>

    <!-- 右: ハンバーガー / バツボタン（モバイル・タブレット） -->
    <div class="flex justify-end">
      <ThemeIcon class="hidden lg:inline-block" />
      <button
        id="menu-toggle"
        class="lg:hidden"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <!-- ハンバーガーアイコン -->
        <span id="icon-open" class="flex w-6 flex-col gap-1">
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
        </span>
        <!-- バツアイコン -->
        <span
          id="icon-close"
          class="hidden h-6 w-6 items-center justify-center text-xl leading-none"
          >✕</span
        >
      </button>
    </div>
  </div>

  <!-- モバイル: ドロップダウンメニュー -->
  <nav id="mobile-menu" class="hidden border-t border-neutral-200 lg:hidden">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class={`block border-b border-neutral-100 px-8 py-4 text-sm tracking-widest uppercase transition-colors hover:bg-neutral-50 ${isActive(link.href) ? "underline underline-offset-4" : ""}`}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle")
  const menu = document.getElementById("mobile-menu")

  const iconOpen = document.getElementById("icon-open")
  const iconClose = document.getElementById("icon-close")

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden")
    menu?.classList.toggle("hidden", isOpen)
    toggle.setAttribute("aria-expanded", String(!isOpen))
    iconOpen?.classList.toggle("hidden", !isOpen)
    iconClose?.classList.toggle("hidden", isOpen)
    iconClose?.classList.toggle("flex", !isOpen)
  })
</script>
