---
import { Image } from "astro:assets"

import ThemeIcon from "./ThemeIcon.astro"

import icon from "@/assets/icon.jpg"

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Music", href: "/music/" },
  { label: "Blogs", href: "/blogs/" },
  { label: "Contact", href: "/contact/" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href)
---

<header class="w-full">
  <div
    class="grid h-16 grid-cols-[1fr_auto_1fr] items-center border-b border-neutral-200 px-8 dark:border-neutral-700"
  >
    <!-- デスクトップ: ナビリンク（左） -->
    <nav class="hidden gap-8 lg:flex">
      {
        navLinks.map((link) =>
          isActive(link.href) ? (
            <div class="text-sm tracking-widest uppercase underline decoration-neutral-400 underline-offset-4">
              {link.label}
            </div>
          ) : (
            <a
              href={link.href}
              class="text-sm tracking-widest uppercase transition-opacity hover:opacity-80"
            >
              {link.label}
            </a>
          ),
        )
      }
    </nav>

    <!-- モバイル・タブレット: 左は空白 -->
    <div class="lg:hidden"></div>

    <!-- 中央: アイコン -->
    <a href="/" class="justify-self-center">
      <Image
        id="nav-icon"
        src={icon}
        alt="Hydrometeor"
        width={40}
        height={40}
        class="rounded-full object-contain"
      />
    </a>

    <!-- 右: ハンバーガー / バツボタン（モバイル・タブレット） -->
    <div class="flex items-center justify-end gap-4">
      <ThemeIcon class="hidden lg:inline-block" />
      <button
        id="menu-toggle"
        class="cursor-pointer lg:hidden"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <!-- ハンバーガーアイコン -->
        <span id="icon-open" class="flex w-6 flex-col gap-1">
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
          <span class="block h-px w-full bg-current"></span>
        </span>
        <!-- バツアイコン -->
        <span
          id="icon-close"
          class="hidden h-6 w-6 items-center justify-center text-xl leading-none"
          >✕</span
        >
      </button>
    </div>
  </div>

  <!-- モバイル: ドロップダウンメニュー -->
  <nav
    id="mobile-menu"
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out lg:hidden"
  >
    <div class="overflow-hidden">
      {
        navLinks.map((link) =>
          isActive(link.href) ? (
            <div class="block border-b border-neutral-100 px-8 py-4 text-center text-sm tracking-widest uppercase underline underline-offset-4 dark:border-neutral-700">
              {link.label}
            </div>
          ) : (
            <a
              href={link.href}
              class="block border-b border-neutral-100 px-8 py-4 text-center text-sm tracking-widest uppercase transition-colors hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800"
            >
              {link.label}
            </a>
          ),
        )
      }
      <div
        class="border-b border-neutral-100 px-8 py-4 text-center dark:border-neutral-700"
      >
        <ThemeIcon />
      </div>
    </div>
  </nav>
</header>

<script>
  const setupMenuToggle = () => {
    const toggle = document.getElementById("menu-toggle")
    const menu = document.getElementById("mobile-menu")
    const iconOpen = document.getElementById("icon-open")
    const iconClose = document.getElementById("icon-close")

    toggle?.addEventListener("click", () => {
      const willOpen = toggle.getAttribute("aria-expanded") !== "true"
      menu?.classList.toggle("grid-rows-[1fr]", willOpen)
      menu?.classList.toggle("grid-rows-[0fr]", !willOpen)
      toggle.setAttribute("aria-expanded", String(willOpen))
      iconOpen?.classList.toggle("hidden", willOpen)
      iconClose?.classList.toggle("hidden", !willOpen)
      iconClose?.classList.toggle("flex", willOpen)
    })
  }

  // View Transitions 後も再バインドされるよう astro:page-load で初期化する
  document.addEventListener("astro:page-load", setupMenuToggle)
</script>
