---
interface Props {
  id: `G-${string}`
}

const { id } = Astro.props
---

<script
  is:inline
  async
  src={`https://www.googletagmanager.com/gtag/js?id=${id}`}></script>
<script is:inline define:vars={{ id }}>
  window.dataLayer = window.dataLayer || []
  function gtag() {
    // eslint-disable-next-line no-undef
    dataLayer.push(arguments)
  }
  gtag("js", new Date())

  gtag("config", id)
</script>
