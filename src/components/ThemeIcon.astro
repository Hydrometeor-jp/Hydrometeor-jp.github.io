---
import { Sun, Moon } from "@lucide/astro"

const { class: className } = Astro.props
---

<button
  class={`js-theme-toggle border-0 bg-none hover:opacity-80 cursor-pointer ${className || ""}`}
  aria-label="テーマを切り替える"
>
  <Sun aria-hidden="true" class="w-7.5 dark:hidden" />
  <Moon aria-hidden="true" class="hidden w-7.5 dark:block" />
</button>

<script is:inline>
  // イベント委譲で document に一度だけバインドする。
  // document は View Transitions を跨いで保持されるため、
  // 遷移で入れ替わったボタンにも対応できる。
  if (!window.__themeToggleBound) {
    window.__themeToggleBound = true

    document.addEventListener("click", (event) => {
      const toggle = event.target?.closest?.(".js-theme-toggle")
      if (!toggle) return

      const element = document.documentElement
      const isDark = element.getAttribute("data-theme") === "dark"

      if (isDark) {
        element.removeAttribute("data-theme")
      } else {
        element.setAttribute("data-theme", "dark")
      }

      localStorage.setItem("theme", isDark ? "light" : "dark")
    })
  }
</script>
