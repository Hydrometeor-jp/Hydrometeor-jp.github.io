---
import { Image } from "astro:assets"

import Layout from "@/layouts/Layout.astro"
import { getNewsList } from "@/libs/microcms"
import { formatDate } from "@/libs/util"

import bandcampHeader from "@/assets/bandcamp_header.png"

const newsList = await getNewsList()
---

<Layout>
  <!-- ヒーロー画像 -->
  <div class="w-full">
    <Image
      src={bandcampHeader}
      alt="Hydrometeor"
      class="min-h-50 w-full object-cover"
      widths={[640, 1280, 1920]}
      sizes="100vw"
    />
  </div>

  <!-- ニュースセクション -->
  <section class="mx-auto max-w-4xl px-8 py-16">
    <h2 class="mb-8 tracking-widest uppercase">News</h2>
    <ul class="flex flex-col gap-4">
      {
        newsList.map((news) => (
          <li class="text-sm">
            {formatDate(news.date)}: {news.title}
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
