---
import Layout from "@/layouts/Layout.astro"
import { getBlogsList } from "@/libs/microcms"
import { formatDate } from "@/libs/util"

export async function getStaticPaths() {
  const blogs = await getBlogsList()
  return blogs.map((blog) => ({
    params: { id: blog.id },
    props: { blog },
  }))
}

const { blog } = Astro.props
---

<Layout title={blog.title}>
  <section class="mx-auto max-w-4xl px-8 py-16">
    <a
      href="/blogs/"
      class="mb-8 block text-sm text-neutral-500 hover:underline dark:text-neutral-400"
      >← Blogs</a
    >
    <h1 class="mb-4 text-3xl">{blog.title}</h1>
    {
      (blog.publishedAt || blog.updatedAt) && (
        <div class="mb-8 flex gap-4 text-sm text-neutral-500 dark:text-neutral-400">
          {blog.publishedAt && (
            <span>公開日: {formatDate(blog.publishedAt)}</span>
          )}
          {blog.updatedAt && (
            <span>最終更新日: {formatDate(blog.updatedAt)}</span>
          )}
        </div>
      )
    }
    <div
      class="prose prose-base max-w-none prose-neutral dark:prose-invert"
      set:html={blog.body}
    />
  </section>
</Layout>
