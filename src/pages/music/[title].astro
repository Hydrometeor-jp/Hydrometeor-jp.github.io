---
import IconLink from "@/components/IconLink.astro"
import Layout from "@/layouts/Layout.astro"
import { getMusicList } from "@/libs/microcms"
import { paddingZero, toMusicSlug } from "@/libs/util"

export async function getStaticPaths() {
  const { contents: music } = await getMusicList()
  return music.map((music) => ({
    params: { title: toMusicSlug(music.title) },
    props: { music },
  }))
}

const { music } = Astro.props
---

<Layout title={music.title}>
  <section class="mx-auto max-w-4xl px-8 py-16">
    <div class="flex flex-col gap-16 md:flex-row">
      <!-- サムネイル -->
      <div class="shrink-0">
        <img
          src={`${music.thumbnail.url}?w=600&fm=webp`}
          alt={music.thumbnail.alt ?? music.title}
          width={300}
          height={300}
          class="w-full object-cover md:w-72"
        />

        <div class="mt-8">
          {
            music.iconLinks && (
              <div class="flex justify-center gap-2">
                {music.iconLinks
                  .split("\n")
                  .map((url) => url.trim())
                  .filter((url) => url.length > 0)
                  .map((url) => (
                    <IconLink url={url} />
                  ))}
              </div>
            )
          }
        </div>
      </div>

      <!-- タイトル + トラックリスト -->
      <div class="flex flex-col gap-8">
        <h1 class="text-2xl">{music.title}</h1>

        {
          music.trackList && music.trackList.length > 0 && (
            <ol class="flex flex-col gap-2">
              {music.trackList.map((track, i) => (
                <li class="grid grid-cols-[2rem_1fr] gap-x-4 text-sm">
                  <span class="text-neutral-400">{paddingZero(i + 1, 2)}</span>
                  <span>
                    {track.artistLinks.map((artist, j) => (
                      <>
                        {artist.url ? (
                          <a
                            href={artist.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="underline transition-colors hover:text-neutral-500"
                          >
                            {artist.name}
                          </a>
                        ) : (
                          <span>{artist.name}</span>
                        )}
                        {j < track.artistLinks.length - 1 && (
                          <span class="mr-1 text-neutral-400">, </span>
                        )}
                      </>
                    ))}
                    <span class="mx-2 text-neutral-400">—</span>
                    <span>{track.title}</span>
                  </span>
                </li>
              ))}
            </ol>
          )
        }
      </div>
    </div>
    {
      (music.spotifyAlbumID ||
        music.bandcampEmbedUrl ||
        music.soundcloudEmbedUrl ||
        music.youtubeMovieID) && (
        <div class="mt-16 flex flex-col gap-8">
          {music.spotifyAlbumID && (
            <iframe
              src={`https://open.spotify.com/embed/album/${music.spotifyAlbumID}?utm_source=generator`}
              title={`${music.title} - Spotify`}
              width="100%"
              height="352"
              class="mx-auto max-w-120"
              allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
              loading="lazy"
            />
          )}
          {music.bandcampEmbedUrl && (
            <iframe
              src={music.bandcampEmbedUrl}
              title={`${music.title} - Bandcamp`}
              seamless
              class="mx-auto h-[472px] w-full max-w-120 border-0"
            />
          )}
          {music.soundcloudEmbedUrl && (
            <iframe
              src={music.soundcloudEmbedUrl}
              title={`${music.title} - SoundCloud`}
              width="100%"
              height="400"
              allow="autoplay"
              loading="lazy"
              scrolling="no"
              frameborder="no"
              class="mx-auto max-w-120"
            />
          )}

          {music.youtubeMovieID && (
            <div class="relative aspect-video w-full">
              <iframe
                src={`https://www.youtube.com/embed/${music.youtubeMovieID}`}
                title={`${music.title} - YouTube`}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                class="absolute inset-0 h-full w-full"
              />
            </div>
          )}
        </div>
      )
    }
  </section>
</Layout>
