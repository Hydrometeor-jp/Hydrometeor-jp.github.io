---
import { ClientRouter } from "astro:transitions"

import NavBar from "@/components/NavBar.astro"
import GoogleAnalytics from "@/components/GoogleAnalytics.astro"

import "@/styles/global.css"

interface Props {
  title?: string
}

const { title } = Astro.props
const pageTitle = title ? `${title} | Hydrometeor` : "Hydrometeor"
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Zen+Old+Mincho&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <GoogleAnalytics id="G-7QHM8HZTWY" />
    <script is:inline>
      // View Transitions で遷移すると <html> の属性が遷移先の静的HTMLに
      // 差し替えられ data-theme が失われるため、初回ロード時に加えて
      // astro:after-swap（描画前に発火）でもテーマを再適用する。
      function applyTheme() {
        document.documentElement.setAttribute(
          "data-theme",
          localStorage.theme === "dark" ||
            (!("theme" in localStorage) &&
              window.matchMedia("(prefers-color-scheme: dark)").matches)
            ? "dark"
            : "light",
        )
      }

      applyTheme()
      document.addEventListener("astro:after-swap", applyTheme)
    </script>
  </head>
  <body class="overflow-x-hidden">
    <NavBar />
    <main>
      <slot />
    </main>
  </body>
</html>
