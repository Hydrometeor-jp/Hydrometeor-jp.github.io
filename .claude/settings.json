{
  "permissions": {
    "allow": [
      "Bash(npm run:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git branch -D:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore .:*)"
    ]
  }
}
